<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.PhotoSyncClient" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/neon_cyan</item>
        <item name="colorPrimaryVariant">@color/neon_purple</item>
        <item name="colorOnPrimary">@color/bg_space</item>
        <item name="android:windowBackground">@color/bg_space</item>
        <item name="android:statusBarColor">@color/bg_space</item>
        <item name="android:navigationBarColor">@color/bg_space</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>
    <style name="Theme.AppCompat.Translucent" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <!-- Aurora popup menu theme — applied via ContextThemeWrapper -->
    <style name="AuroraPopupTheme" parent="ThemeOverlay.AppCompat.Dark">
        <item name="android:colorBackground">@color/card_bg</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:popupBackground">@drawable/popup_bg_aurora</item>
        <item name="popupMenuStyle">@style/AuroraPopupMenuStyle</item>
    </style>

    <style name="AuroraPopupMenuStyle" parent="Widget.AppCompat.PopupMenu">
        <item name="android:popupBackground">@drawable/popup_bg_aurora</item>
    </style>
</resources>

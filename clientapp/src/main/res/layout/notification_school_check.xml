<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#0A0A1E"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <!-- Header row: icon + "Did you teach here?" -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Did you teach here today?"
            android:textColor="#7BBCCC"
            android:textSize="11sp"
            android:letterSpacing="0.08"
            android:textAllCaps="true" />

        <TextView
            android:id="@+id/tv_school_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="school"
            android:textColor="#00897B"
            android:textSize="10sp"
            android:textAllCaps="true"
            android:letterSpacing="0.06" />
    </LinearLayout>

    <!-- School name -->
    <TextView
        android:id="@+id/tv_school_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="School Name"
        android:textColor="#00CFA8"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="6dp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1A00CFA8"
        android:layout_marginBottom="6dp" />

    <!-- From / to time -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FROM "
            android:textColor="#7BBCCC"
            android:textSize="10sp"
            android:textAllCaps="true" />

        <TextView
            android:id="@+id/tv_time_from"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  →  "
            android:textColor="#7BBCCC"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_time_to"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  (~0 min)"
            android:textColor="#7BBCCC"
            android:textSize="11sp" />

    </LinearLayout>

</LinearLayout>

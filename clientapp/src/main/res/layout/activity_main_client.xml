<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Animated starfield background -->
    <com.photosync.client.ui.StarfieldView
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Main content column -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ── Top banner ─────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:background="@color/banner_bg"
            android:elevation="4dp">

            <TextView
                android:id="@+id/tv_banner_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/app_name"
                android:textColor="@color/neon_cyan"
                android:textSize="17sp"
                android:letterSpacing="0.04"
                android:textStyle="bold"
                android:fontFamily="@font/space_grotesk"/>

            <ImageButton
                android:id="@+id/btn_menu"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_more_vert"
                android:tint="@color/neon_cyan"
                android:contentDescription="Menu"/>
        </LinearLayout>

        <!-- ── Scrollable card area ───────────────────────────────────── -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- Card 1: STATUS (cyan) -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/neon_card_cyan"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="STATUS"
                            android:textColor="@color/neon_cyan"
                            android:textSize="11sp"
                            android:letterSpacing="0.16"
                            android:textStyle="bold"
                            android:fontFamily="@font/space_grotesk"
                            android:layout_marginBottom="10dp"/>

                        <TextView android:id="@+id/tv_permission_status"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:fontFamily="@font/sora"
                            android:layout_marginBottom="4dp"/>

                        <TextView android:id="@+id/tv_battery_status"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:fontFamily="@font/sora"
                            android:layout_marginBottom="10dp"/>

                        <TextView android:id="@+id/tv_hub_status"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:fontFamily="@font/sora"
                            android:text="◎  Listening for hub…"/>

                        <TextView android:id="@+id/tv_accessibility_status"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:fontFamily="@font/sora"
                            android:layout_marginTop="4dp"/>

                        <TextView android:id="@+id/tv_tailscale_status"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/neon_cyan"
                            android:textSize="12sp"
                            android:fontFamily="@font/jetbrains_mono"
                            android:layout_marginTop="4dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="12dp">

                            <androidx.appcompat.widget.SwitchCompat
                                android:id="@+id/sw_mobile_data"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:thumbTint="@color/neon_cyan"
                                android:trackTint="@color/neon_deep"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sync on mobile data"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp"
                                android:layout_marginStart="8dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </FrameLayout>

                <!-- Card 2: TRANSFER PROGRESS (purple) -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/neon_card_purple"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="UPLOAD"
                            android:textColor="@color/neon_purple"
                            android:textSize="11sp"
                            android:letterSpacing="0.16"
                            android:textStyle="bold"
                            android:fontFamily="@font/space_grotesk"
                            android:layout_marginBottom="10dp"/>

                        <!-- Session progress (file count) -->
                        <TextView android:id="@+id/tv_progress_label"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:fontFamily="@font/jetbrains_mono"
                            android:text="Idle"
                            android:layout_marginBottom="6dp"/>

                        <ProgressBar
                            android:id="@+id/pb_sync"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:max="100"
                            android:progress="0"
                            android:progressTint="@color/neon_purple"
                            android:progressBackgroundTint="#36a98bff"
                            android:layout_marginBottom="14dp"/>

                        <!-- Current file progress -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CURRENT FILE"
                            android:textColor="@color/neon_purple"
                            android:alpha="0.7"
                            android:textSize="9sp"
                            android:letterSpacing="0.16"
                            android:textStyle="bold"
                            android:fontFamily="@font/space_grotesk"
                            android:layout_marginBottom="4dp"/>

                        <TextView android:id="@+id/tv_current_file"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:fontFamily="@font/jetbrains_mono"
                            android:text="—"
                            android:layout_marginBottom="6dp"/>

                        <ProgressBar
                            android:id="@+id/pb_file"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="5dp"
                            android:indeterminate="false"
                            android:max="10000"
                            android:progress="0"
                            android:progressTint="@color/neon_cyan"
                            android:progressBackgroundTint="#2222d3ee"
                            android:visibility="invisible"
                            android:layout_marginBottom="10dp"/>

                        <TextView android:id="@+id/tv_mb_remaining"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/neon_purple"
                            android:textSize="11sp"
                            android:fontFamily="@font/jetbrains_mono"
                            android:text=""/>
                    </LinearLayout>
                </FrameLayout>

                <!-- Card 3: COMPRESSION (green) -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/neon_card_green"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="COMPRESSION"
                            android:textColor="@color/neon_cyan"
                            android:textSize="11sp"
                            android:letterSpacing="0.16"
                            android:textStyle="bold"
                            android:fontFamily="@font/space_grotesk"
                            android:layout_marginBottom="10dp"/>

                        <TextView android:id="@+id/tv_compression_label"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:fontFamily="@font/jetbrains_mono"
                            android:text="Idle"
                            android:layout_marginBottom="8dp"/>

                        <ProgressBar
                            android:id="@+id/pb_compression"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:indeterminate="false"
                            android:max="100"
                            android:progress="0"
                            android:progressTint="@color/neon_green"
                            android:progressBackgroundTint="#2200CFA8"
                            android:visibility="invisible"/>

                    </LinearLayout>
                </FrameLayout>

                <!-- Card 4: HUB FILES (green) -->
                <FrameLayout
                    android:id="@+id/card_hub_files"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/neon_card_green"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Header row: label + MORE button -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="HUB FILES"
                                android:textColor="@color/neon_green"
                                android:textSize="11sp"
                                android:letterSpacing="0.2"
                                android:textStyle="bold"
                                android:fontFamily="@font/jetbrains_mono"/>

                            <TextView
                                android:id="@+id/btn_hub_files_more"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="MORE →"
                                android:textColor="@color/neon_green"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/jetbrains_mono"
                                android:padding="4dp"
                                android:background="?attr/selectableItemBackgroundBorderless"/>
                        </LinearLayout>

                        <!-- 5 thumbnail slots in a horizontal row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="70dp"
                            android:orientation="horizontal"
                            android:weightSum="5">

                            <ImageView
                                android:id="@+id/iv_hub_thumb_0"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:layout_marginEnd="3dp"
                                android:scaleType="centerCrop"
                                android:background="@color/card_bg"/>

                            <ImageView
                                android:id="@+id/iv_hub_thumb_1"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:layout_marginEnd="3dp"
                                android:scaleType="centerCrop"
                                android:background="@color/card_bg"/>

                            <ImageView
                                android:id="@+id/iv_hub_thumb_2"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:layout_marginEnd="3dp"
                                android:scaleType="centerCrop"
                                android:background="@color/card_bg"/>

                            <ImageView
                                android:id="@+id/iv_hub_thumb_3"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:layout_marginEnd="3dp"
                                android:scaleType="centerCrop"
                                android:background="@color/card_bg"/>

                            <ImageView
                                android:id="@+id/iv_hub_thumb_4"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:scaleType="centerCrop"
                                android:background="@color/card_bg"/>

                        </LinearLayout>

                        <!-- Status text (shown while loading or if hub unreachable) -->
                        <TextView
                            android:id="@+id/tv_hub_files_status"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Connect to hub to see recent files"
                            android:textColor="@color/text_muted"
                            android:textSize="11sp"
                            android:fontFamily="@font/jetbrains_mono"/>

                    </LinearLayout>
                </FrameLayout>

                <!-- Card 5: LIVE LOG (amber) -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/neon_card_amber"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LIVE LOG"
                            android:textColor="@color/neon_amber"
                            android:textSize="11sp"
                            android:letterSpacing="0.16"
                            android:textStyle="bold"
                            android:fontFamily="@font/space_grotesk"
                            android:layout_marginBottom="10dp"/>

                        <ScrollView
                            android:id="@+id/scroll_log"
                            android:layout_width="match_parent"
                            android:layout_height="300dp"
                            android:scrollbars="none">

                            <TextView
                                android:id="@+id/tv_log"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/jetbrains_mono"
                                android:textSize="11sp"
                                android:textColor="@color/text_secondary"
                                android:lineSpacingMultiplier="1.3"
                                android:text="Waiting for service…"/>
                        </ScrollView>
                    </LinearLayout>
                </FrameLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

</FrameLayout>

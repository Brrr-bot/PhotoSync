<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="2dp"
    android:background="@color/card_bg">

    <ImageView
        android:id="@+id/iv_thumb"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:scaleType="centerCrop"
        android:background="@color/bg_space"/>

    <!-- Download indicator overlay -->
    <FrameLayout
        android:id="@+id/overlay_downloading"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:background="#BB000000"
        android:gravity="center"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:indeterminateTint="@color/neon_cyan"/>
    </FrameLayout>

    <!-- Selection tint overlay -->
    <View
        android:id="@+id/selection_overlay"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:background="#AA22d3ee"
        android:visibility="gone"/>

    <!-- Selection checkmark -->
    <ImageView
        android:id="@+id/iv_check"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_gravity="top|end"
        android:layout_margin="5dp"
        android:src="@drawable/ic_check_circle"
        android:tint="@color/neon_cyan"
        android:visibility="gone"/>

    <!-- File name -->
    <TextView
        android:id="@+id/tv_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#CC000000"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:textColor="@color/text_secondary"
        android:textSize="9sp"
        android:fontFamily="@font/jetbrains_mono"
        android:maxLines="1"
        android:ellipsize="middle"/>

</FrameLayout>

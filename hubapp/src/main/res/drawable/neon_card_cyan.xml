<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Fading glow layers — extend outside view (parent needs clipChildren=false) -->
    <item android:left="-20dp" android:top="-20dp" android:right="-20dp" android:bottom="-20dp">
        <shape android:shape="rectangle"><corners android:radius="36dp"/><solid android:color="#0222d3ee"/></shape>
    </item>
    <item android:left="-14dp" android:top="-14dp" android:right="-14dp" android:bottom="-14dp">
        <shape android:shape="rectangle"><corners android:radius="30dp"/><solid android:color="#0522d3ee"/></shape>
    </item>
    <item android:left="-9dp" android:top="-9dp" android:right="-9dp" android:bottom="-9dp">
        <shape android:shape="rectangle"><corners android:radius="25dp"/><solid android:color="#0E22d3ee"/></shape>
    </item>
    <item android:left="-5dp" android:top="-5dp" android:right="-5dp" android:bottom="-5dp">
        <shape android:shape="rectangle"><corners android:radius="21dp"/><solid android:color="#1A22d3ee"/></shape>
    </item>
    <item android:left="-2dp" android:top="-2dp" android:right="-2dp" android:bottom="-2dp">
        <shape android:shape="rectangle"><corners android:radius="18dp"/><solid android:color="#2822d3ee"/></shape>
    </item>
    <!-- Card body: 16dp corners (Aurora radius-lg), solid background + stroke -->
    <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="16dp"/>
            <solid android:color="@color/card_bg"/>
            <stroke android:width="1.5dp" android:color="@color/neon_cyan"/>
        </shape>
    </item>
</layer-list>

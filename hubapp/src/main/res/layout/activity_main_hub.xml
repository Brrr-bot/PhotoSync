<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.photosync.hub.ui.StarfieldView
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:background="@color/banner_bg"
            android:elevation="4dp">

            <TextView
                android:id="@+id/tv_banner_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/app_name"
                android:textColor="@color/neon_cyan"
                android:textSize="17sp"
                android:letterSpacing="0.04"
                android:textStyle="bold"
                android:fontFamily="@font/space_grotesk"/>

            <ImageButton
                android:id="@+id/btn_menu"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_more_vert"
                android:tint="@color/neon_cyan"
                android:contentDescription="Menu"/>
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:scrollbars="none"
            android:clipChildren="false"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <!-- STATUS (cyan) -->
                <com.photosync.hub.ui.GlowCardLayout
                    android:id="@+id/glow_card_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="28dp">
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/card_surface_cyan"
                        android:padding="20dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="STATUS"
                                android:textColor="@color/neon_cyan"
                                android:textSize="11sp"
                                android:letterSpacing="0.16"
                                android:textStyle="bold"
                                android:fontFamily="@font/space_grotesk"
                                android:layout_marginBottom="10dp"/>
                            <TextView android:id="@+id/tv_usb_status"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp"
                                android:fontFamily="@font/sora"
                                android:layout_marginBottom="4dp"/>
                            <TextView android:id="@+id/tv_battery_status"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp"
                                android:fontFamily="@font/sora"
                                android:layout_marginBottom="4dp"/>
                            <TextView android:id="@+id/tv_accessibility_status"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp"
                                android:fontFamily="@font/sora"
                                android:layout_marginBottom="4dp"/>
                            <TextView android:id="@+id/tv_tailscale_status"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/neon_cyan"
                                android:textSize="12sp"
                                android:fontFamily="@font/jetbrains_mono"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </FrameLayout>
                </com.photosync.hub.ui.GlowCardLayout>

                <!-- TRANSFER (purple) -->
                <com.photosync.hub.ui.GlowCardLayout
                    android:id="@+id/glow_card_transfer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="28dp">
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/card_surface_purple"
                        android:padding="20dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TRANSFER"
                                android:textColor="@color/neon_purple"
                                android:textSize="11sp"
                                android:letterSpacing="0.16"
                                android:textStyle="bold"
                                android:fontFamily="@font/space_grotesk"
                                android:layout_marginBottom="10dp"/>
                            <TextView android:id="@+id/tv_progress_label"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"
                                android:fontFamily="@font/jetbrains_mono"
                                android:text="Idle"
                                android:layout_marginBottom="6dp"/>
                            <ProgressBar
                                android:id="@+id/pb_sync"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="match_parent"
                                android:layout_height="8dp"
                                android:max="100"
                                android:progress="0"
                                android:progressDrawable="@drawable/progress_bar_purple"
                                android:layout_marginBottom="14dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CURRENT FILE"
                                android:textColor="@color/neon_purple"
                                android:alpha="0.7"
                                android:textSize="9sp"
                                android:letterSpacing="0.16"
                                android:textStyle="bold"
                                android:fontFamily="@font/space_grotesk"
                                android:layout_marginBottom="4dp"/>
                            <TextView android:id="@+id/tv_current_file"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"
                                android:fontFamily="@font/jetbrains_mono"
                                android:text="—"
                                android:layout_marginBottom="6dp"/>
                            <ProgressBar
                                android:id="@+id/pb_file"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="match_parent"
                                android:layout_height="5dp"
                                android:indeterminate="false"
                                android:max="10000"
                                android:progress="0"
                                android:progressDrawable="@drawable/progress_bar_cyan"
                                android:visibility="invisible"
                                android:layout_marginBottom="10dp"/>
                            <TextView android:id="@+id/tv_mb_remaining"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/neon_purple"
                                android:textSize="11sp"
                                android:fontFamily="@font/jetbrains_mono"
                                android:text=""/>
                        </LinearLayout>
                    </FrameLayout>
                </com.photosync.hub.ui.GlowCardLayout>

                <!-- COMPRESSION (green) -->
                <com.photosync.hub.ui.GlowCardLayout
                    android:id="@+id/glow_card_compression"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="28dp">
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/card_surface_green"
                        android:padding="20dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="COMPRESSION"
                                android:textColor="@color/neon_green"
                                android:textSize="11sp"
                                android:letterSpacing="0.16"
                                android:textStyle="bold"
                                android:fontFamily="@font/space_grotesk"
                                android:layout_marginBottom="10dp"/>
                            <TextView android:id="@+id/tv_sync_status"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"
                                android:fontFamily="@font/jetbrains_mono"
                                android:text="Idle"
                                android:layout_marginBottom="8dp"/>
                            <ProgressBar
                                android:id="@+id/pb_compression"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="match_parent"
                                android:layout_height="8dp"
                                android:indeterminate="false"
                                android:max="100"
                                android:progress="0"
                                android:progressDrawable="@drawable/progress_bar_green"
                                android:visibility="invisible"/>
                        </LinearLayout>
                    </FrameLayout>
                </com.photosync.hub.ui.GlowCardLayout>

                <!-- LIVE LOG (amber) -->
                <com.photosync.hub.ui.GlowCardLayout
                    android:id="@+id/glow_card_log"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/card_surface_amber"
                        android:padding="20dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="LIVE LOG"
                                android:textColor="@color/neon_amber"
                                android:textSize="11sp"
                                android:letterSpacing="0.16"
                                android:textStyle="bold"
                                android:fontFamily="@font/space_grotesk"
                                android:layout_marginBottom="10dp"/>
                            <ScrollView
                                android:id="@+id/scroll_log"
                                android:layout_width="match_parent"
                                android:layout_height="260dp"
                                android:scrollbars="none">
                                <TextView
                                    android:id="@+id/tv_log"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/jetbrains_mono"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_secondary"
                                    android:lineSpacingMultiplier="1.3"
                                    android:text="Waiting for service…"/>
                            </ScrollView>
                        </LinearLayout>
                    </FrameLayout>
                </com.photosync.hub.ui.GlowCardLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</FrameLayout>
